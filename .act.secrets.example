# Copy to .act.secrets and set real values. .act.secrets is gitignored.
# Used by: npm run ci, npm run test:e2e, npm run build:act
#
# Format: one KEY=VALUE per line (no spaces around =).
# These are passed to act as secrets (--secret-file .act.secrets).

# For GHCR: use your GitHub username and a PAT with write:packages (or use GITHUB_TOKEN only)
REGISTRY_USERNAME=your_github_username
REGISTRY_PASSWORD=your_github_pat_or_token

# Required for release steps and GHCR fallback
GITHUB_TOKEN=your_github_pat

# For npm publishing (falls back to GITHUB_TOKEN for GitHub Packages)
# NPM_TOKEN=your_npm_token
