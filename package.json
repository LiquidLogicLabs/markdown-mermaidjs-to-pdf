{
  "name": "@liquidlogiclabs/markdown-mermaidjs-to-pdf",
  "version": "1.1.1",
  "description": "Convert markdown with Mermaid diagrams to PDF",
  "main": "src/root/app/index.js",
  "bin": {
    "markdown-mermaidjs-to-pdf": "src/root/app/index.js",
    "mdmmjs2pdf": "src/root/app/index.js"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LiquidLogicLabs/markdown-mermaidjs-to-pdf.git"
  },
  "homepage": "https://github.com/LiquidLogicLabs/markdown-mermaidjs-to-pdf#readme",
  "bugs": {
    "url": "https://github.com/LiquidLogicLabs/markdown-mermaidjs-to-pdf/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "start": "node src/root/app/index.js",
    "dev": "nodemon src/root/app/index.js",
    "test": "jest",
    "build": "npm run test:e2e",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "preversion": "npm test",
    "release": "npm run release:patch",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "release:dry-run": "npm test",
    "ci": "act push -W .github/workflows/ci.yml $( [ -f .act.env ] && echo '--var-file .act.env' ) $( [ -f .act.secrets ] && echo '--secret-file .act.secrets' ) --container-options \"--user $(id -u):$(id -g)\"",
    "test:e2e": "act workflow_dispatch -W .github/workflows/e2e.yml $( [ -f .act.env ] && echo '--var-file .act.env' ) $( [ -f .act.secrets ] && echo '--secret-file .act.secrets' ) --container-options \"--user $(id -u):$(id -g)\"",
    "build:act": "act workflow_dispatch -W .github/workflows/release.yml --input tag=v$(node -p \"require('./package.json').version\") $( [ -f .act.env ] && echo '--var-file .act.env' ) $( [ -f .act.secrets ] && echo '--secret-file .act.secrets' ) --container-options \"--user $(id -u):$(id -g)\"",
    "run:docker": "docker run --rm -v \"$(pwd)/data/input:/data/input\" -v \"$(pwd)/data/output:/data/output\" -v \"$(pwd)/data/logs:/data/logs\" -e LOGGING_ENABLED=true -e LOG_LEVEL=info ghcr.io/liquidlogiclabs/markdown-mermaidjs-to-pdf:latest"
  },
  "keywords": [
    "markdown",
    "pdf",
    "mermaid",
    "converter",
    "mermaidjs",
    "markdown-to-pdf",
    "cli",
    "puppeteer"
  ],
  "author": "LiquidLogicLabs",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.1.1",
    "gray-matter": "^4.0.3",
    "jsdom": "^23.0.1",
    "marked": "^9.1.6",
    "mermaid": "^10.6.1",
    "pdf-lib": "^1.17.1",
    "puppeteer": "24.14.0",
    "rimraf": "6.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
