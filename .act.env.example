# Copy to .act.env and set values. .act.env is gitignored.
# Used by: npm run ci, npm run test:e2e, npm run build:act (act --var-file .act.env).
#
# npm scripts also pass --container-options "--user $(id -u):$(id -g)" so act runs as your user (Linux/macOS).
#
# Override workflow vars when running with act. Format: one KEY=VALUE per line (no spaces around =).

# Build locally without pushing (image loaded into Docker)
IMAGE_BUILD_MODE=load

# Optional overrides (defaults shown)
# REGISTRY_NAME=ghcr.io
# REGISTRY_ORG=liquidlogiclabs
# IMAGE_NAME=markdown-mermaidjs-to-pdf
# DOCKER_PLATFORMS=linux/amd64,linux/arm64
# CREATE_RELEASE=false
# DEBUG=false
